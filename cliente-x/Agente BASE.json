    {
      "parameters": {
        "jsCode": "// Function node no n8n\nreturn items.map(item => {\n  const key = item.json?.body?.data?.key || {};\n  const { remoteJid, remoteJidAlt } = key;\n\n  let whatsappJid = null;\n\n  if (remoteJidAlt && remoteJidAlt.includes('@s.whatsapp.net')) {\n    whatsappJid = remoteJidAlt;\n  } else if (remoteJid && remoteJid.includes('@s.whatsapp.net')) {\n    whatsappJid = remoteJid;\n  }\n\n  // Se você quer que o OUTPUT tenha só o JID:\n  return {\n    json: {\n      whatsappJid,\n    },\n  };\n});"
      },
