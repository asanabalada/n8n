    {
      "parameters": {
        "functionCode": "const plantId = 5386328;\nconst plantas = $json.result || [];\n\nlet planta = null;\nfor (const p of plantas) {\n  if (p.stationId === plantId || p.id === plantId) {\n    planta = p;\n    break;\n  }\n}\n\nconst plantName = planta?.stationame || planta?.name || planta?.stationName || 'UFV VINICIUS';\n\nreturn [{\n  plant_name: plantName,\n  plant_id: plantId\n}];"
