    {
      "parameters": {
        "jsCode": "// Garante que todos os dados estão presentes com fallback\nconst data = {\n  energia_kwh: String($json.energia_kwh || '0.00'),\n  mes_kwh: String($json.mes_kwh || '0.00'),\n  plant_name: String($json.plant_name || 'UFV VINICIUS'),\n  plant_id: $json.plant_id || 5386328,\n  chartDataUrl: String($json.chartDataUrl || '')\n};\n\nconsole.log('=== Dados Consolidados ===', JSON.stringify(data, null, 2));\n\nreturn [data];"
