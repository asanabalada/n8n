    {
      "parameters": {
        "jsCode": "// Executa o código de geração do número aleatório\nconst min = 30;\nconst max = 60;\nconst randomNumber = Math.floor(Math.random() * (max - min + 1)) + min;\n\n// Retorna o valor em um array de objetos com a propriedade \"json\"\nreturn [\n  {\n    json: {\n      randomNumber: randomNumber,\n    },\n  },\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1664,
        -2320
      ],
      "id": "f10f794f-f942-4e07-86c0-d4936f2a1160",
      "name": "Code1"
    },
    {
      "parameters": {
        "jsCode": "// Pega o conteúdo que veio da OpenAI\nconst content = $input.item.json.message.content;\nlet data;\n\n// 1. Tenta fazer o parse se vier como texto (String)\nif (typeof content === 'string') {\n  try {\n    // Remove possíveis marcadores de markdown\n    const cleanJson = content.replace(/```json|```/g, '');\n    data = JSON.parse(cleanJson);\n  } catch (e) {\n    return { json: { content: [] } };\n  }\n} else {\n  // Se já for objeto, usa direto\n  data = content;\n}\n\n// 2. Normaliza: Procura onde está o Array de mensagens\nlet finalArray = [];\n\nif (Array.isArray(data)) {\n  // Caso 1: Veio o array direto\n  finalArray = data;\n} else if (data.json && Array.isArray(data.json)) {\n  // Caso 2: Veio dentro de 'json' (O SEU CASO ATUAL)\n  finalArray = data.json;\n} else if (data.messages && Array.isArray(data.messages)) {\n  // Caso 3: Veio dentro de 'messages'\n  finalArray = data.messages;\n} else if (data.values && Array.isArray(data.values)) {\n  // Caso 4: Veio dentro de 'values'\n  finalArray = data.values;\n} else if (data.response && Array.isArray(data.response)) {\n  // Caso 5: Veio dentro de 'response' (caso atual)\n  finalArray = data.response;\n}\n\n// Retorna no formato que o Split Out espera\nreturn {\n  json: {\n    content: finalArray\n  }\n};"
      },
