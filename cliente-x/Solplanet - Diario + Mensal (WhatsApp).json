    {
      "parameters": {
        "jsCode": "const d = $now; // Luxon DateTime\nconst yyyy = d.toFormat('yyyy');\nconst mm = d.toFormat('LL');\nconst dd = d.toFormat('dd');\n\nfor (const item of items) {\n  if (item.binary?.chart) {\n    item.binary.chart.fileName = `grafico-mensal-${yyyy}-${mm}.png`;\n  }\n}\n\nreturn items;"
      },
