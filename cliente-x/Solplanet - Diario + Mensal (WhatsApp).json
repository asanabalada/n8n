    {
      "parameters": {
        "jsCode": "// ---- 1) Pega labels (dias) ----\nconst labels = $json.result?.x || $json.result?.labels || [];\n\n// ---- 2) Pega o array de energia do mês (descobre a chave automaticamente) ----\nconst dataObj = $json.result?.data || {};\nconst firstKey = Object.keys(dataObj)[0];          // ex: \"energy\" ou \"ac\" etc.\nconst valuesRaw = dataObj[firstKey] || [];\n\n// ---- 3) Normaliza para número e soma ----\nconst values = valuesRaw.map(v => Number(v) || 0);\nconst totalMes = values.reduce((acc, v) => acc + v, 0);\n\n// ---- 4) Monta o chart (Chart.js / QuickChart) ----\nreturn [\n  {\n    chart: {\n      type: \"bar\",\n      data: {\n        labels,\n        datasets: [\n          {\n            label: `Acumulado do mês (kWh): ${totalMes.toFixed(2)}`,\n            data: values,\n          },\n        ],\n      },\n      options: {\n        plugins: {\n          title: {\n            display: true,\n            text: `Acumulado do mês (kWh): ${totalMes.toFixed(2)}`,\n          },\n          legend: { display: true },\n        },\n        scales: {\n          y: { beginAtZero: true },\n        },\n      },\n    },\n    totalMes: totalMes.toFixed(2),\n  },\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        560,
        480
      ],
      "id": "53be2de2-9ad7-4f0f-8352-6f2c82f6e20f",
      "name": "Montar Chart Config Mes"
