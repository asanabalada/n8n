        "messages": {
          "values": [
            {
              "content": "=Você é um assistente de triagem de leads de um SaaS. Analise a seguinte mensagem de um lead e classifique o nível de interesse dele em relação a uma prospecção.\n\nResponda APENAS com um arquivo JSON contendo duas chaves:\n- \"status\": que deve ser estritamente uma destas opções: \"Interessado\", \"Sem Interesse\" ou \"Dúvida\".\n- \"resumo\": um resumo de no máximo 5 palavras do que ele disse.\n\nMensagem do lead: {{ $json.resposta }}",
              "role": "system"
            }
          ]
        },
        "jsonOutput": true,
        "options": {}
      },
