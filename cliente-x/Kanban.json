    {
      "parameters": {
        "jsCode": "// Extrai o corpo da requisição do Webhook\nconst webhookData = $input.first().json.body;\n\n// Verifica se existe a estrutura de mensagem da Evolution API\nif (webhookData && webhookData.data && webhookData.data.messages) {\n  const msgInfo = webhookData.data.messages[0];\n  \n  // Ignora mensagens enviadas por você mesmo (fromMe: true)\n  if (msgInfo.key.fromMe === false) {\n    \n    // Extrai o telefone (removendo o sufixo @s.whatsapp.net)\n    const telefone = msgInfo.key.remoteJid.split('@')[0];\n    \n    // Tenta encontrar o texto da mensagem em diferentes formatos possíveis\n    let textoResposta = \"\";\n    if (msgInfo.message && msgInfo.message.conversation) {\n      textoResposta = msgInfo.message.conversation;\n    } else if (msgInfo.message && msgInfo.message.extendedTextMessage) {\n      textoResposta = msgInfo.message.extendedTextMessage.text;\n    }\n\n    // Retorna os dados limpos\n    return [{\n      json: {\n        telefone: telefone,\n        resposta: textoResposta,\n        tipo: \"mensagem_recebida\"\n      }\n    }];\n  }\n}\n\n// Se não for uma mensagem válida, retorna vazio para parar o fluxo\nreturn [];"
      },
      "name": "Filtra Mensagem",
      "type": "n8n-nodes-base.code",
