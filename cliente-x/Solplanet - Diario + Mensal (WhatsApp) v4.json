    {
      "parameters": {
        "functionCode": "const unit = String($json.result?.unit || '').toLowerCase();\nconst labels = $json.result?.x || [];\nconst arr = $json.result?.data?.ac || [];\n\n// soma do mês (como vem na API)\nlet sum = 0;\nfor (const v of arr) sum += parseFloat(v) || 0;\n\n// tenta achar o valor do DIA ATUAL dentro do gráfico mensal\nconst hojeLabel = String(new Date().getDate()).padStart(2, '0');\nconst idx = labels.findIndex(l => String(l).padStart(2, '0') === hojeLabel);\nlet hojeNoMes = idx >= 0 ? (parseFloat(arr[idx]) || 0) : 0;\n\n// se vier em kW e for leitura “granular”, normaliza\nif (unit === 'kw' && labels.length > 40) {\n  sum = sum / 6;\n  hojeNoMes = hojeNoMes / 6;\n}\n\nreturn [{\n  mes_kwh: sum.toFixed(2),\n  mes_hoje_kwh: hojeNoMes.toFixed(2),\n  mes_inclui_hoje: hojeNoMes > 0,\n}];"
      },
